# ============================================
# CONFIGURACIÓN DE PUERTO Y BASE DE DATOS
# ============================================
PORT=4000
MONGO_URI=mongodb://mongo:27017/agrosentinel
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ============================================
# CONFIGURACIÓN DE DISPOSITIVOS
# ============================================
DEVICE_OFFLINE_SECONDS=120
CRITICAL_LEVEL_PCT=20

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# AUTENTICACIÓN JWT
# ============================================
AUTH_JWT_SECRET=change_this_secret_to_a_long_random_string
AUTH_JWT_EXPIRES=12h

# ============================================
# TELEGRAM (Opcional)
# ============================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# ARCA / AFIP - FACTURACIÓN ELECTRÓNICA
# ============================================

# Modo de entorno: mock | homologacion | produccion
# - mock: Simulación (no requiere certificados, CAE falso)
# - homologacion: Pruebas con AFIP (requiere certificado de testing)
# - produccion: Facturas reales con validez fiscal
ARCA_ENVIRONMENT=mock

# URLs de Homologación (para pruebas)
ARCA_WSAA_URL_HOMO=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL_HOMO=https://wswhomo.afip.gov.ar/wsfev1/service.asmx

# URLs de Producción (para facturas reales)
ARCA_WSAA_URL_PROD=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL_PROD=https://servicios1.afip.gov.ar/wsfev1/service.asmx

# Habilitar ARCA (true | false)
ARCA_ENABLED=true

# Certificado digital (.p12) - Solo para homologacion y produccion
# Generar con OpenSSL:
# 1. openssl genrsa -out MiClavePrivada.key 2048
# 2. openssl req -new -key MiClavePrivada.key -subj "/C=AR/O=TU_EMPRESA/CN=NOMBRE_SISTEMA/serialNumber=CUIT TU_CUIT" -out MiPedidoCSR.csr
# 3. Obtener certificado desde portal AFIP
# 4. openssl pkcs12 -export -in certificado.crt -inkey MiClavePrivada.key -out certificado.p12 -name "alias"
ARCA_CERT_PATH=
ARCA_CERT_PASSWORD=
# Directorio persistente para key/csr/crt generados por la app
CERT_STORAGE_DIR=./certs

# CUIT de la empresa (sin guiones)
ARCA_CUIT=20123456789

# Punto de venta (número de terminal)
ARCA_PTO_VTA=1

# Token y Sign (obtenidos manualmente de WSAA o mediante el servicio WSAA)
# Para testing rápido en modo mock, dejar vacíos
ARCA_TOKEN=
ARCA_SIGN=
